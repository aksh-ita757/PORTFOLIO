<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Akshita Bhardwaj — Full-Stack Dev & AI Tinkerer</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
:root{
  --pink:#FF2D78;
  --purple:#7C3AED;
  --green:#00C58E;
  --yellow:#FFD600;
  --blue:#3B82F6;
  --bg:#FFFBF7;
  --ink:#0A0A14;
  --soft:#6B7280;
  --white:#FFFFFF;
  --border:2.5px solid var(--ink);
  --r:16px;
  --shadow:5px 5px 0 var(--ink);
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
ul{list-style:none}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--pink);border-radius:99px}

/* ── NAV ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 40px;
  background:rgba(255,251,247,0.88);
  backdrop-filter:blur(16px);
  border-bottom:2px solid rgba(10,10,20,0.08);
}
.nav-logo{font-family:'Syne',sans-serif;font-weight:900;font-size:1.2rem;letter-spacing:-0.03em}
.nav-logo span{color:var(--pink)}
.nav-links{display:flex;align-items:center;gap:6px}
.nav-links a{
  font-family:'JetBrains Mono',monospace;font-size:0.8rem;font-weight:600;
  padding:8px 16px;border-radius:99px;transition:all .2s;
}
.nav-links a:hover{background:var(--ink);color:var(--white)}
.nav-cta{
  background:var(--pink)!important;color:var(--white)!important;
  border:2.5px solid var(--ink);
  box-shadow:3px 3px 0 var(--ink);
}
.nav-cta:hover{transform:translate(-1px,-2px);box-shadow:5px 5px 0 var(--ink)!important}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;z-index:1001}
.hamburger span{width:24px;height:2.5px;background:var(--ink);border-radius:2px;transition:.3s}
.hamburger.on span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
.hamburger.on span:nth-child(2){opacity:0}
.hamburger.on span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;align-items:center;
  padding:100px 40px 60px;
  max-width:1280px;margin:0 auto;
  gap:40px;
}
.hero-left{flex:1.1}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--yellow);border:var(--border);border-radius:99px;
  padding:8px 18px;margin-bottom:28px;
  font-family:'JetBrains Mono',monospace;font-size:0.78rem;font-weight:700;
}
.badge-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 1.4s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.5);opacity:.6}}
.hero h1{
  font-family:'Syne',sans-serif;font-weight:900;
  font-size:clamp(3rem,7.5vw,5.6rem);
  line-height:.98;letter-spacing:-0.04em;
  margin-bottom:22px;
}
.hero h1 .outline{
  -webkit-text-stroke:3px var(--ink);
  color:transparent;
}
.hero h1 .highlight{
  background:var(--yellow);
  -webkit-text-stroke:0;
  color:var(--ink);
  padding:0 8px;
  border-radius:8px;
  display:inline-block;
}
.hero-sub{
  font-size:1.12rem;color:var(--soft);line-height:1.7;
  max-width:480px;margin-bottom:36px;
}
.hero-sub strong{color:var(--ink);font-weight:700}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:44px}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 28px;border:var(--border);border-radius:99px;
  font-family:'JetBrains Mono',monospace;font-weight:700;font-size:0.85rem;
  box-shadow:var(--shadow);background:var(--white);color:var(--ink);
  transition:transform .18s,box-shadow .18s;cursor:pointer;
}
.btn:hover{transform:translate(-2px,-3px);box-shadow:8px 8px 0 var(--ink)}
.btn:active{transform:translate(0,0);box-shadow:2px 2px 0 var(--ink)}
.btn-pink{background:var(--pink);color:var(--white)}
.btn-purple{background:var(--purple);color:var(--white);box-shadow:5px 5px 0 var(--purple)}
.btn-purple:hover{box-shadow:8px 8px 0 var(--purple)}
.hero-chips{display:flex;flex-wrap:wrap;gap:10px}
.chip{
  border:2px solid rgba(10,10,20,.13);border-radius:99px;
  padding:7px 16px;font-family:'JetBrains Mono',monospace;font-size:.75rem;font-weight:600;
  background:var(--white);animation:chipFloat 3s ease-in-out infinite;
}
.chip:nth-child(2){animation-delay:.4s}
.chip:nth-child(3){animation-delay:.8s}
.chip:nth-child(4){animation-delay:1.2s}
.chip:nth-child(5){animation-delay:1.6s}
@keyframes chipFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}

/* HERO RIGHT */
.hero-right{
  flex:.85;
  display:flex;flex-direction:column;
  align-items:center;gap:20px;
}
.hero-photo-frame{
  position:relative;
  width:100%;max-width:340px;
}
.hero-photo-frame img{
  width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;
  border:var(--border);border-radius:24px;
  box-shadow:10px 10px 0 var(--pink);
}
.hero-card{
  position:absolute;bottom:-20px;left:-20px;
  background:var(--white);border:var(--border);border-radius:14px;
  padding:14px 18px;box-shadow:var(--shadow);
  font-family:'JetBrains Mono',monospace;font-size:.76rem;font-weight:700;
  display:flex;align-items:center;gap:8px;
  animation:cardFloat 2.5s ease-in-out infinite;
}
.hero-card-emoji{font-size:1.3rem}
@keyframes cardFloat{0%,100%{transform:rotate(-2deg) translateY(0)}50%{transform:rotate(-2deg) translateY(-6px)}}
.hero-card2{
  position:absolute;top:-16px;right:-16px;
  background:var(--yellow);border:var(--border);border-radius:14px;
  padding:12px 16px;box-shadow:var(--shadow);
  font-family:'JetBrains Mono',monospace;font-size:.74rem;font-weight:700;
  text-align:center;
  animation:cardFloat2 3.2s ease-in-out infinite .5s;
}
@keyframes cardFloat2{0%,100%{transform:rotate(3deg)}50%{transform:rotate(3deg) translateY(-5px)}}

/* ── MARQUEE ── */
.marquee-wrap{
  border-top:var(--border);border-bottom:var(--border);
  background:var(--ink);overflow:hidden;padding:16px 0;
}
.marquee-track{
  display:flex;width:max-content;
  animation:marquee 22s linear infinite;
}
.marquee-track:hover{animation-play-state:paused}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.marquee-item{
  white-space:nowrap;padding:0 28px;
  font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;
  color:var(--white);letter-spacing:-.01em;
}
.marquee-item span{color:var(--yellow);margin:0 8px}

/* ── ABOUT ── */
.about{
  max-width:1280px;margin:0 auto;
  padding:110px 40px;
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.about-photos{position:relative;height:420px}
.ab-photo{
  position:absolute;
  border:var(--border);border-radius:20px;overflow:hidden;
  background:var(--white);
  transition:transform .3s ease;cursor:pointer;
}
.ab-photo:hover{z-index:5;transform:scale(1.05) rotate(0deg)!important}
.ab-photo img{width:100%;height:100%;object-fit:cover}
.ab1{width:230px;height:280px;top:0;left:0;transform:rotate(-4deg);box-shadow:8px 8px 0 var(--purple)}
.ab2{width:210px;height:260px;bottom:0;right:20px;transform:rotate(5deg);box-shadow:8px 8px 0 var(--green)}
.about-text{}
.section-label{
  font-family:'JetBrains Mono',monospace;font-size:.78rem;font-weight:700;
  color:var(--pink);letter-spacing:.12em;text-transform:uppercase;
  display:flex;align-items:center;gap:10px;margin-bottom:16px;
}
.section-label::after{content:'';flex:1;height:2px;background:var(--pink);max-width:40px}
.about-text h2{
  font-family:'Syne',sans-serif;font-weight:900;
  font-size:clamp(2rem,3.5vw,2.8rem);line-height:1.1;letter-spacing:-.03em;
  margin-bottom:24px;
}
.about-text h2 em{font-style:normal;color:var(--purple)}
.about-text p{color:var(--soft);font-size:1.02rem;line-height:1.75;margin-bottom:16px}
.about-text p strong{color:var(--ink)}
.stat-row{display:flex;gap:16px;flex-wrap:wrap;margin-top:28px}
.stat-box{
  border:var(--border);border-radius:14px;padding:16px 22px;
  background:var(--white);box-shadow:4px 4px 0 var(--ink);
  font-family:'Syne',sans-serif;
}
.stat-box strong{display:block;font-size:1.8rem;font-weight:900;line-height:1;color:var(--pink)}
.stat-box span{font-size:.75rem;color:var(--soft);font-family:'JetBrains Mono',monospace}

/* ── PROJECTS ── */
.projects{padding:80px 40px;max-width:1280px;margin:0 auto}
.projects-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:60px;gap:20px;flex-wrap:wrap}
.projects-header h2{font-family:'Syne',sans-serif;font-weight:900;font-size:clamp(2.2rem,4.5vw,3.4rem);letter-spacing:-.04em;line-height:1}
.project-block{
  border:var(--border);border-radius:24px;overflow:hidden;
  background:var(--white);box-shadow:var(--shadow);
  margin-bottom:32px;
  display:grid;grid-template-columns:1fr 1fr;
  min-height:420px;
}
.project-block.flip{direction:rtl}
.project-block.flip>*{direction:ltr}
.project-info{padding:50px 44px;display:flex;flex-direction:column;justify-content:center}
.project-emoji-big{font-size:2.6rem;margin-bottom:16px}
.project-tag{
  display:inline-block;
  background:var(--yellow);border:2px solid var(--ink);
  border-radius:99px;padding:5px 14px;
  font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:700;
  margin-bottom:16px;
}
.project-info h3{font-family:'Syne',sans-serif;font-weight:900;font-size:1.9rem;letter-spacing:-.03em;margin-bottom:10px}
.project-info p{color:var(--soft);font-size:.97rem;line-height:1.7;margin-bottom:24px;max-width:380px}
.proj-stack{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:28px}
.proj-tag{
  background:var(--bg);border:1.5px solid rgba(10,10,20,.12);
  border-radius:99px;padding:5px 12px;
  font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--soft);
}
.proj-links{display:flex;gap:10px;flex-wrap:wrap}
.proj-btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:11px 20px;border:var(--border);border-radius:99px;
  font-family:'JetBrains Mono',monospace;font-size:.76rem;font-weight:700;
  background:var(--white);box-shadow:3px 3px 0 var(--ink);
  transition:all .15s;cursor:pointer;
}
.proj-btn:hover{transform:translate(-1px,-2px);box-shadow:5px 5px 0 var(--ink)}
.proj-btn.dark{background:var(--ink);color:var(--white)}

/* PROJECT DEMO WINDOWS */
.project-demo{
  background:#F0F4FF;border-left:var(--border);
  position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;
  min-height:380px;
}
.project-block.flip .project-demo{border-left:none;border-right:var(--border)}
.browser-frame{
  width:88%;max-width:420px;
  background:var(--white);border:2px solid var(--ink);border-radius:14px;
  overflow:hidden;box-shadow:6px 6px 0 rgba(10,10,20,.15);
}
.browser-bar{
  background:#F3F4F6;border-bottom:1.5px solid var(--ink);
  padding:10px 14px;display:flex;align-items:center;gap:8px;
}
.b-dot{width:10px;height:10px;border-radius:50%;border:1.5px solid rgba(0,0,0,.2)}
.b-dot.r{background:#FF5F57}.b-dot.y{background:#FEBC2E}.b-dot.g{background:#28C840}
.b-url{
  flex:1;margin-left:10px;background:var(--white);border:1.5px solid rgba(0,0,0,.1);
  border-radius:6px;padding:4px 10px;
  font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--soft);
}
.browser-content{padding:18px;min-height:240px;position:relative;overflow:hidden}

/* HerGuardian demo */
.demo-map{
  width:100%;height:100%;background:linear-gradient(135deg,#667eea20,#764ba220);
  border-radius:8px;position:relative;min-height:220px;overflow:hidden;
}
.map-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(100,100,200,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(100,100,200,.08) 1px,transparent 1px);
  background-size:24px 24px;
}
.map-pin{
  position:absolute;width:16px;height:16px;
  background:var(--pink);border:2px solid var(--white);border-radius:50%;
  top:50%;left:50%;transform:translate(-50%,-50%);z-index:2;
  animation:pinPulse 1.5s ease-in-out infinite;
}
@keyframes pinPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,45,120,.5)}70%{box-shadow:0 0 0 14px rgba(255,45,120,0)}}
.map-rings{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
.ring{
  position:absolute;border:2px solid var(--pink);border-radius:50%;
  top:50%;left:50%;transform:translate(-50%,-50%);
  opacity:0;animation:ringExpand 2s ease-out infinite;
}
.ring:nth-child(1){width:40px;height:40px;animation-delay:0s}
.ring:nth-child(2){width:70px;height:70px;animation-delay:.6s}
.ring:nth-child(3){width:100px;height:100px;animation-delay:1.2s}
@keyframes ringExpand{0%{transform:translate(-50%,-50%) scale(.5);opacity:.8}100%{transform:translate(-50%,-50%) scale(1);opacity:0}}
.sos-btn{
  position:absolute;top:14px;right:14px;
  background:var(--pink);color:var(--white);border:2px solid var(--white);
  border-radius:99px;padding:7px 14px;
  font-family:'Syne',sans-serif;font-size:.72rem;font-weight:900;
  box-shadow:0 4px 14px rgba(255,45,120,.4);
  animation:sosPulse 2s ease-in-out infinite;cursor:default;
}
@keyframes sosPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
.alert-toast{
  position:absolute;bottom:14px;left:50%;transform:translateX(-50%);
  background:var(--ink);color:var(--white);border-radius:10px;padding:8px 16px;
  font-family:'JetBrains Mono',monospace;font-size:.65rem;font-weight:600;
  white-space:nowrap;display:flex;align-items:center;gap:6px;
  animation:toastSlide 3s ease-in-out infinite;
}
@keyframes toastSlide{0%,100%{opacity:0;transform:translateX(-50%) translateY(10px)}15%,85%{opacity:1;transform:translateX(-50%) translateY(0)}}

/* BudgetBridge demo */
.demo-dash{padding:8px}
.dash-toprow{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px}
.dash-card{
  background:var(--bg);border:1.5px solid rgba(10,10,20,.08);border-radius:10px;
  padding:10px 12px;
}
.dash-card-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--soft);margin-bottom:4px}
.dash-card-value{font-family:'Syne',sans-serif;font-weight:900;font-size:.95rem;color:var(--ink)}
.dash-card.green .dash-card-value{color:var(--green)}
.dash-card.red .dash-card-value{color:var(--pink)}
.chart-area{background:var(--bg);border:1.5px solid rgba(10,10,20,.08);border-radius:10px;padding:12px}
.chart-label{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--soft);margin-bottom:10px}
.bars{display:flex;align-items:flex-end;gap:7px;height:80px}
.bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bar{
  width:100%;border-radius:5px 5px 0 0;border:1.5px solid var(--ink);
  animation:barGrow 1.5s ease-out infinite alternate;
}
.bar.b1{height:60%;background:var(--purple);animation-delay:0s}
.bar.b2{height:80%;background:var(--pink);animation-delay:.15s}
.bar.b3{height:45%;background:var(--green);animation-delay:.3s}
.bar.b4{height:70%;background:var(--blue);animation-delay:.45s}
.bar.b5{height:90%;background:var(--yellow);animation-delay:.6s}
@keyframes barGrow{from{transform:scaleY(.7)}to{transform:scaleY(1)}}
.bar-label{font-family:'JetBrains Mono',monospace;font-size:.52rem;color:var(--soft)}

/* SmartMart demo */
.demo-shop{padding:8px}
.shop-search{
  background:var(--bg);border:1.5px solid rgba(10,10,20,.15);border-radius:8px;
  padding:8px 12px;margin-bottom:10px;
  font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--soft);
  display:flex;align-items:center;gap:8px;
}
.shop-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.shop-item{
  background:var(--bg);border:1.5px solid rgba(10,10,20,.08);border-radius:10px;
  padding:10px;text-align:center;
  transition:transform .2s;
  animation:itemPop .5s ease-out both;
}
.shop-item:nth-child(2){animation-delay:.1s}
.shop-item:nth-child(3){animation-delay:.2s}
.shop-item:nth-child(4){animation-delay:.3s}
.shop-item:nth-child(5){animation-delay:.4s}
.shop-item:nth-child(6){animation-delay:.5s}
@keyframes itemPop{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}
.shop-img{font-size:1.5rem;margin-bottom:6px}
.shop-name{font-family:'JetBrains Mono',monospace;font-size:.56rem;color:var(--ink);margin-bottom:4px;font-weight:600}
.shop-price{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:800;color:var(--pink)}
.shop-add{
  width:100%;margin-top:6px;background:var(--ink);color:var(--white);
  border:none;border-radius:5px;padding:4px;
  font-family:'JetBrains Mono',monospace;font-size:.52rem;font-weight:700;cursor:pointer;
  transition:background .2s;
}
.shop-add:hover{background:var(--pink)}
.cart-badge{
  position:absolute;top:10px;right:10px;
  background:var(--pink);color:var(--white);border:2px solid var(--ink);
  border-radius:99px;padding:4px 10px;
  font-family:'Syne',sans-serif;font-size:.7rem;font-weight:900;
  animation:badgePop .3s ease-out;
}

/* ── SKILLS ── */
.skills-wrap{
  background:var(--ink);border-top:var(--border);border-bottom:var(--border);
  padding:80px 40px;
}
.skills-inner{max-width:1280px;margin:0 auto}
.skills-wrap .section-label{color:var(--yellow)}
.skills-wrap .section-label::after{background:var(--yellow)}
.skills-wrap h2{
  font-family:'Syne',sans-serif;font-weight:900;color:var(--white);
  font-size:clamp(2rem,4vw,3rem);letter-spacing:-.04em;margin-bottom:44px;
}
.skills-cloud{display:flex;flex-wrap:wrap;gap:12px}
.stag{
  border:2px solid rgba(255,255,255,.2);border-radius:99px;
  padding:11px 22px;color:var(--white);
  font-family:'JetBrains Mono',monospace;font-size:.82rem;font-weight:600;
  transition:all .2s;cursor:default;
}
.stag:hover{background:var(--white);color:var(--ink);transform:translateY(-3px) rotate(-1.5deg);border-color:var(--white)}
.stag.hot{background:var(--pink);border-color:var(--pink);color:var(--white)}
.stag.hot:hover{background:var(--white);color:var(--pink);border-color:var(--white)}
.stag.cool{background:var(--purple);border-color:var(--purple);color:var(--white)}
.stag.warm{background:var(--green);border-color:var(--green);color:var(--white)}
.stag.gold{background:var(--yellow);border-color:var(--yellow);color:var(--ink)}

/* ── EDUCATION ── */
.edu-section{padding:80px 40px;max-width:1280px;margin:0 auto}
.edu-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:48px}
.edu-card{
  background:var(--white);border:var(--border);border-radius:20px;
  padding:36px;box-shadow:var(--shadow);
}
.edu-card h3{font-family:'Syne',sans-serif;font-weight:900;font-size:1.25rem;margin-bottom:8px}
.edu-card .meta{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--soft);margin-bottom:20px}
.cgpa-badge{
  display:inline-flex;align-items:baseline;gap:4px;
  background:var(--yellow);border:var(--border);border-radius:10px;
  padding:8px 16px;margin-bottom:18px;
}
.cgpa-badge b{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:900;line-height:1}
.cgpa-badge span{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--soft)}
.course-text{font-size:.88rem;color:var(--soft);line-height:1.7}

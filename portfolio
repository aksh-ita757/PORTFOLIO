<script>
// NAV
const ham = document.getElementById('ham');
const nl = document.getElementById('navlinks');
ham.addEventListener('click', () => { ham.classList.toggle('on'); nl.classList.toggle('on'); document.body.style.overflow = nl.classList.contains('on') ? 'hidden' : ''; });
nl.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { ham.classList.remove('on'); nl.classList.remove('on'); document.body.style.overflow = ''; }));

// NAV SHADOW
const nav = document.querySelector('.nav');
window.addEventListener('scroll', () => { nav.style.boxShadow = scrollY > 20 ? '0 2px 24px rgba(10,10,20,.1)' : ''; }, { passive: true });

// SCROLL REVEAL
const ro = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const sibs = [...e.target.parentElement.querySelectorAll('.reveal:not(.in)')];
      const i = sibs.indexOf(e.target);
      setTimeout(() => e.target.classList.add('in'), i * 100);
      ro.unobserve(e.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

// CART ANIMATION
let cartCount = 0;
document.querySelectorAll('.shop-add').forEach(btn => {
  btn.addEventListener('click', function() {
    cartCount++;
    const badge = document.getElementById('cartBadge');
    badge.textContent = '🛒 ' + cartCount;
    badge.style.animation = 'none';
    badge.offsetHeight;
    badge.style.animation = 'badgePop .3s ease-out';
    this.textContent = '✓ Added';
    this.style.background = 'var(--green)';
    setTimeout(() => { this.textContent = '+ Add'; this.style.background = ''; }, 1200);
  });
});
</script>
